{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CM-SS13 Launcher",
  "identifier": "com.cm-ss13.launcher",
  "app": {
    "windows": [
      {
        "title": "CM-SS13",
        "width": 900,
