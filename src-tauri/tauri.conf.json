{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SS13 Launcher",
  "identifier": "com.ss13.launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SS13 Launcher",
        "width": 900,
        "height": 500,
        "decorations": false,
        "resizable": false,
        "center": true,
        "transparent": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "resources": [
      "icons/ss13/icon.png"
    ],
    "publisher": "SS13",
    "copyright": "Copyright 2026 SS13",
    "category": "Game",
    "shortDescription": "Game launcher for SS13 servers",
    "longDescription": "Launcher for SS13 servers. Manages BYOND game client installations.",
    "windows": {
      "allowDowngrades": true,
      "nsis": {
        "installMode": "both",
        "installerIcon": "icons/ss13/icon.ico"
      },
      "wix": null,
      "webviewInstallMode": {
        "silent": true,
        "type": "embedBootstrapper"
      }
    },
    "active": true,
    "targets": "all",
    "icon": [
      "icons/ss13/32x32.png",
      "icons/ss13/128x128.png",
      "icons/ss13/128x128@2x.png",
      "icons/ss13/icon.icns",
      "icons/ss13/icon.ico"
    ]
  }
}
